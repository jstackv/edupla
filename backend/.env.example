# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/edupla?retryWrites=true&w=majority
DB_NAME=edupla

# Session
SESSION_SECRET=replace_with_a_long_random_string_here

# CORS – set to your Vercel frontend URL after deploying
ALLOWED_ORIGINS=https://your-frontend.vercel.app

NODE_ENV=production
